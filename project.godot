; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MultiHitter"
run/main_scene="uid://mk335xicjn4p"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Network="*uid://b36suepgtihek"
TileRunInstancesGlobal="*uid://b6fg6pu2bfi14"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/always_on_top=true
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"

[dotnet]

project/assembly_name="MultiHitter"

[editor_plugins]

enabled=PackedStringArray("res://addons/func_godot/plugin.cfg", "res://addons/tile-run-instances/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/func_godot/": "teal",
"res://assets/": "green",
"res://scenes/": "red",
"res://scripts/": "yellow",
"res://shaders/": "pink",
"res://trenchbroom/": "blue"
}

